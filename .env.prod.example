# Production — copy to server as /opt/timia/.env.prod (do not commit real secrets)
# Domain: https://timia.online
# Build happens on the Lighthouse server (no TCR).
#
# Not used on server: apps/api/.env, apps/web/.env.local (those are local dev only).
# Compose: ./deploy/dc-prod.sh ps   (always loads this file)

# PostgreSQL
POSTGRES_USER=timia
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=timia

# API
DATABASE_URL=postgresql+psycopg://timia:CHANGE_ME@db:5432/timia
JWT_SECRET=CHANGE_ME
JWT_ISSUER=timia
JWT_AUDIENCE=timia-web
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=14
ENABLE_DEV_DB_TABLES=false
CORS_ORIGINS=https://timia.online

# Web image build arg (docker compose build on server)
NEXT_PUBLIC_API_BASE_URL=https://timia.online/api
