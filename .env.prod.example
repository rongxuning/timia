# Production template — on server copy to /etc/timia/.env.prod (NOT inside git repo).
#   sudo cp .env.prod.example /etc/timia/.env.prod && sudo nano /etc/timia/.env.prod
# Domain: https://timia.online
#
# Do NOT keep secrets in /opt/timia/.env.prod — git pull may delete or conflict with tracked copies.
# Local dev only: codes/api/.env, codes/web/.env.local

# PostgreSQL
POSTGRES_USER=timia
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=timia

# API
DATABASE_URL=postgresql+psycopg://timia:CHANGE_ME@db:5432/timia
JWT_SECRET=CHANGE_ME
JWT_ISSUER=timia
JWT_AUDIENCE=timia-web
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=14
ENABLE_DEV_DB_TABLES=false
CORS_ORIGINS=https://timia.online

# Web image build arg (docker compose build on server)
NEXT_PUBLIC_API_BASE_URL=https://timia.online/api
