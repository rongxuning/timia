# codes/api/.env
# 本地 Docker 默认库（见根目录 docker-compose.yml）：用户/库名均为 timia。
DATABASE_URL=postgresql+psycopg://timia:timia@localhost:5432/timia
JWT_SECRET=dev_secret_change_me
JWT_ISSUER=timia
JWT_AUDIENCE=timia-web
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=14
# When true, exposes GET /dev/db-tables for the code documentation UI (local dev only).
ENABLE_DEV_DB_TABLES=true

# codes/web/.env.local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
